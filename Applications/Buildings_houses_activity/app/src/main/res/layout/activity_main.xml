<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/view_face">

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="24sp"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:padding="16dp" />

    <ImageButton
        android:id="@+id/buttonstart"
        android:layout_width="110dp"
        android:layout_height="90dp"
        android:layout_below="@id/textView"
        android:layout_marginTop="230dp"
        android:padding="16dp"
        android:text=""
        android:gravity="center"
        android:scaleType="fitCenter"
        android:src="@drawable/start"
        android:visibility="gone"
        android:contentDescription="start"/>

    <ImageButton
        android:id="@+id/buttonstop"
        android:layout_width="110dp"
        android:layout_height="90dp"
        android:layout_below="@id/textView"
        android:layout_marginTop="230dp"
        android:layout_marginLeft="130dp"
        android:padding="16dp"
        android:text=""
        android:gravity="center"
        android:scaleType="fitCenter"
        android:src="@drawable/stopp"
        android:visibility="gone"
        android:contentDescription="stop"/>


    <ImageButton
        android:id="@+id/buttongo"
        android:layout_width="110dp"
        android:layout_height="90dp"
        android:layout_below="@id/textView"
        android:layout_marginTop="230dp"
        android:layout_marginLeft="520dp"
        android:padding="16dp"
        android:text=""
        android:gravity="center"
        android:scaleType="fitCenter"
        android:src="@drawable/ahead"
        android:visibility="visible"
        android:contentDescription="stop"/>


    <ImageButton
        android:id="@+id/buttoncostruzioni"
        android:layout_width="80dp"
        android:layout_height="70dp"
        android:layout_below="@id/textView"
        android:layout_marginTop="0dp"
        android:layout_marginLeft="550dp"
        android:padding="5dp"
        android:text=""
        android:gravity="center"
        android:scaleType="fitCenter"
        android:src="@drawable/lego"
        android:visibility="visible"
        android:contentDescription="stop"
        android:layout_alignParentEnd="true"/>


    <ImageButton
        android:id="@+id/buttonback"
        android:layout_width="70dp"
        android:layout_height="65dp"
        android:layout_below="@id/textView"
        android:layout_marginTop="0dp"
        android:layout_marginLeft="550dp"
        android:padding="5dp"
        android:text=""
        android:gravity="center"
        android:scaleType="fitCenter"
        android:src="@drawable/back"
        android:visibility="gone"
        android:contentDescription="stop"
        android:layout_alignParentEnd="true"/>


    <ImageView
        android:id="@+id/imageView"
        android:layout_width="449dp"
        android:layout_height="392dp"
        android:layout_below="@id/textView"
        android:layout_marginLeft="100dp"
        android:layout_marginTop="-63dp" />

    <ImageView
        android:id="@+id/casa_yara"
        android:layout_width="210dp"
        android:layout_height="180dp"
        android:layout_below="@id/textView"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="-50dp"
        android:contentDescription="Red color"
        android:padding="4dp"
        android:src="@drawable/casa_yara"
        android:visibility="visible" />

    <ImageView
        android:id="@+id/casa_akio"
        android:layout_width="210dp"
        android:layout_height="180dp"
        android:layout_below="@id/textView"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="140dp"
        android:contentDescription="Orange color"
        android:padding="4dp"
        android:src="@drawable/casa_akio"
        android:visibility="visible" />





    <ImageView
        android:id="@+id/casa_maria"
        android:layout_width="210dp"
        android:layout_height="180dp"
        android:layout_below="@id/textView"
        android:layout_marginLeft="225dp"
        android:layout_marginTop="-50dp"
        android:contentDescription="Yellow color"
        android:padding="4dp"
        android:src="@drawable/casa_maria"
        android:visibility="visible" />


    <ImageView
        android:id="@+id/casa_caterina"
        android:layout_width="200dp"
        android:layout_height="170dp"
        android:layout_below="@id/textView"
        android:layout_marginLeft="220dp"
        android:layout_marginTop="140dp"
        android:contentDescription="Green color"
        android:padding="4dp"
        android:src="@drawable/casa_giulio"
        android:visibility="visible" />


    <ImageView
        android:id="@+id/casa_vish"
        android:layout_width="200dp"
        android:layout_height="170dp"
        android:layout_below="@id/textView"
        android:layout_marginLeft="430dp"
        android:layout_marginTop="45dp"
        android:contentDescription="Blue color"
        android:padding="4dp"
        android:src="@drawable/casa_vish"
        android:visibility="visible" />


</RelativeLayout>







